# Root gitignore for the LMS monorepo (Laravel API + React SPA)

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# Local env files at the root level
.env
.env.*
!.env.example

# Build / dependency caches
**/node_modules
**/vendor
**/dist
**/dist-ssr
**/build

# IDE / agent folders
.idea
.vscode
.claude
.codex
.cursor
.zed
.agents
